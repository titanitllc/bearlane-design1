{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        { "slug": "accent",     "color": "#111827", "name": "Accent"     },
        { "slug": "text",       "color": "#111827", "name": "Text"       },
        { "slug": "muted",      "color": "#6b7280", "name": "Muted"      },
        { "slug": "bg",         "color": "#fafafa", "name": "Background" },
        { "slug": "surface",    "color": "#ffffff", "name": "Surface"    },
        { "slug": "surface-2",  "color": "#f3f4f6", "name": "Surface 2"  },
        { "slug": "border",     "color": "#e5e7eb", "name": "Border"     },
        { "slug": "error",      "color": "#dc2626", "name": "Error"      },
        { "slug": "success",    "color": "#16a34a", "name": "Success"    }
      ],
      "custom": true,
      "customDuotone": false,
      "customGradient": true,
      "defaultGradients": false,
      "defaultPalette": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif",
          "slug": "inter",
          "name": "Inter"
        }
      ],
      "fontSizes": [
        { "slug": "xs",   "size": "0.75rem",  "name": "Extra Small" },
        { "slug": "sm",   "size": "0.875rem", "name": "Small"       },
        { "slug": "md",   "size": "1rem",     "name": "Medium"      },
        { "slug": "lg",   "size": "1.125rem", "name": "Large"       },
        { "slug": "xl",   "size": "1.25rem",  "name": "XL"          },
        { "slug": "2xl",  "size": "1.5rem",   "name": "2XL"         },
        { "slug": "3xl",  "size": "1.875rem", "name": "3XL"         },
        { "slug": "4xl",  "size": "2.25rem",  "name": "4XL"         },
        { "slug": "5xl",  "size": "3rem",     "name": "5XL"         }
      ],
      "customFontSize": true,
      "lineHeight": true,
      "letterSpacing": true
    },
    "spacing": {
      "units": [ "px", "em", "rem", "%", "vw", "vh" ],
      "padding": true,
      "margin": true,
      "blockGap": true,
      "customSpacingSize": true
    },
    "border": {
      "radius": true,
      "color":  true,
      "style":  true,
      "width":  true
    },
    "layout": {
      "contentSize": "780px",
      "wideSize":    "1280px"
    },
    "blocks": {
      "core/button": {
        "border": { "radius": true }
      },
      "core/pullquote": {
        "border": { "color": true, "radius": true, "style": true, "width": true }
      }
    }
  },
  "styles": {
    "color": {
      "background": "#fafafa",
      "text":       "#111827"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter, 'Inter', sans-serif)",
      "fontSize":   "var(--wp--preset--font-size--md)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": { "text": "#111827" },
        ":hover": { "color": { "text": "#374151" } }
      },
      "h1": { "typography": { "fontWeight": "700", "lineHeight": "1.1", "letterSpacing": "-0.03em" } },
      "h2": { "typography": { "fontWeight": "600", "lineHeight": "1.15", "letterSpacing": "-0.02em" } },
      "h3": { "typography": { "fontWeight": "600", "lineHeight": "1.2" } }
    },
    "blocks": {
      "core/separator": {
        "color": { "text": "#e5e7eb" },
        "border": { "color": "#e5e7eb", "width": "1px" }
      }
    }
  }
}
